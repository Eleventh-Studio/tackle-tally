{
  "expo": {
    "name": "Tackle Tally",
    "slug": "tackle-tally",
    "owner": "eleventh-studio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.tackletally.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "tackle-tally",
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Tackle Tally to access your camera to photograph your catches."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Tackle Tally to record the location of your catch."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Tackle Tally to access your photo library.",
          "savePhotosPermission": "Allow Tackle Tally to save catch photos to your library."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fde640e4-61a0-44e8-9234-7aaf108b0132"
      }
    }
  }
}
